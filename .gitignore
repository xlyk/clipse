# build output
/bin/
/clipse

# local runtime config: machine-specific (primary-clone path, worker
# command) — configs/clipse.example.yaml is the committed, documented
# template this is copied from.
/configs/clipse.yaml
/configs/clipse.*.local.yaml

# smoke-test local config + generated artifacts (machine-specific; templates
# are scripts/smoke/smoke.env.example + configs/clipse.smoke.example.yaml).
/scripts/smoke/smoke.env
/scripts/smoke/*.local.yaml
/scripts/smoke/clipse.smoke.yaml
/scripts/smoke/*.log
/scripts/smoke/smoke-manifest.tsv

# databases
*.db
*.db-wal
*.db-shm

# local Clipse runtime state (board database, lock, logs, and worktrees)
/.clipse/

# superpowers ledger (never commit)
.superpowers/

# isolated implementation worktrees
/.worktrees/

# readme-agents-doc local recon cache and GitHub PR intel
.readme-agents-doc/

# go
*.test
*.out

# python
__pycache__/
.venv/
agent/.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
dist/
build/

