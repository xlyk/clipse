# clipse smoke-test configuration.
#
# Copy to scripts/smoke/smoke.env and edit. smoke.env is gitignored and holds
# only machine-specific paths/knobs -- NEVER put API keys here (they come from
# LINEAR_KEY_SOURCE / ANTHROPIC_KEY_SOURCE below). Every value has a default in
# smoke.sh; you usually only need to confirm the repo, team, and paths.

# ---------------------------------------------------------------------------
# Target GitHub repo (throwaway -- reset force-resets its main branch)
# ---------------------------------------------------------------------------

# owner/name of the dedicated smoke target. MUST NOT be your real project.
TARGET_REPO="xlyk/clipse-smoke-target"

# Repo visibility for `setup`. Use "public" if branch protection is not
# available for private repos on your GitHub plan (the merge gate needs main
# to be protected -- setup hard-fails if protection does not apply).
REPO_VISIBILITY="private"

# Git remote URL used to clone the primary and as repo.remote in the config.
# Defaults to SSH: git@github.com:$TARGET_REPO.git. Set an https URL if you
# clone over HTTPS.
# REMOTE_URL="git@github.com:xlyk/clipse-smoke-target.git"

# Base branch and the stable baseline tag reset restores main to.
BASE_BRANCH="main"
BASELINE_TAG="smoke-baseline-py"

# ---------------------------------------------------------------------------
# Linear team (the clipse-development workspace, selected by LINEAR_API_KEY)
# ---------------------------------------------------------------------------

TEAM_KEY="CLI"
TEAM_ID="8b5b3301-8da3-4933-9b07-9efc027bc09d"

# ---------------------------------------------------------------------------
# Local working area (all machine-local, all gitignored)
# ---------------------------------------------------------------------------

# Root for everything the smoke writes locally.
SMOKE_HOME="$HOME/Code/clipse-smoke"

# Dispatcher state dir (kernel SQLite db + singleton lock + worktrees).
BOARD_DIR="$SMOKE_HOME/board"

# Per-issue LangGraph checkpoint dbs (kept outside any worktree).
CHECKPOINTS_DIR="$SMOKE_HOME/checkpoints"

# Primary git clone of TARGET_REPO the dispatcher creates worktrees from.
PRIMARY_CLONE="$SMOKE_HOME/primary"

# Generated dispatcher config (written by smoke.sh from these values each run).
SMOKE_YAML="$SMOKE_HOME/clipse.smoke.yaml"

# Absolute path to the clipse repo (where `make build` runs and the worker's
# `uv --project <CLIPSE_REPO>/agent` lives). Defaults to this script's own repo.
# CLIPSE_REPO="/Users/xlyk/Code/clipse"

# ---------------------------------------------------------------------------
# Credentials (paths to source, or the literal "env" if already exported)
# ---------------------------------------------------------------------------

# LINEAR_API_KEY drives the dispatcher's Linear polling/mirroring. Sourced
# from this file (default ~/.secrets) or set "env" if already exported.
LINEAR_KEY_SOURCE="$HOME/.secrets"

# ANTHROPIC_API_KEY is forwarded to the worker. "env" if already exported, or
# a path to a file (e.g. an app .env) to source it from.
ANTHROPIC_KEY_SOURCE="env"
# ANTHROPIC_KEY_SOURCE="/Users/xlyk/Code/agents/apps/estimator-v2/.env"

# ---------------------------------------------------------------------------
# Dispatcher tuning (written into the generated config)
# ---------------------------------------------------------------------------

POLL_INTERVAL_S="20"
MAX_RUNTIME_S="1800"         # per-worker wall-clock kill (dispatcher max_runtime_s)
MAX_TOKENS_PER_RUN="2000000"
TURN_CAP="3"
MAX_ATTEMPTS="3"
REWORK_CAP="3"
RECOVER_CAP="5"

CAP_GLOBAL="6"
CAP_CODER="3"
CAP_REVIEWER="2"
CAP_GIT_OPERATOR="2"

# --- optional per-lane model overrides (omit to use clipse defaults) ---
# MODEL_CODER="anthropic:claude-sonnet-4-6"
# MODEL_CODER_DOCS="anthropic:claude-sonnet-4-6"
# MODEL_REVIEWER="anthropic:claude-opus-4-6"

# Path to a yaml snippet appended verbatim to the generated config -- use
# for nested blocks like model_params: / shell_allow_list:.
# EXTRA_CONFIG_YAML="$HOME/Code/clipse-smoke/extra.yaml"

# ---------------------------------------------------------------------------
# Run-phase watcher
# ---------------------------------------------------------------------------

TIMEOUT_S="5400"             # give up if the DAG is not all-terminal by here
WATCH_INTERVAL_S="15"        # board poll cadence for the status line

# LINEAR_BOARD_URL: the Linear view scripts/demo/record-demo.sh opens (via
# `open -a Linear`, routed to the desktop app). Set this view to list-layout
# grouped-by-status in Linear ONCE — Linear persists layout+grouping per view.
LINEAR_BOARD_URL="https://linear.app/clipse-development/team/CLI/all"
